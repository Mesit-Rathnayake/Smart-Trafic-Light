<routes>
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5.0" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>

    <!-- Routes including Left and Right turns -->
    <!-- Format: edges="Source To_Center Center_To_Destination" -->
    <route id="s_to_n" edges="B2C C2T"/> <!-- Straight -->
    <route id="s_to_w" edges="B2C C2L"/> <!-- Left Turn -->
    <route id="s_to_e" edges="B2C C2R"/> <!-- Right Turn -->

    <route id="n_to_s" edges="T2C C2B"/> <!-- Straight -->
    <route id="n_to_e" edges="T2C C2R"/> <!-- Left Turn -->
    <route id="n_to_w" edges="T2C C2L"/> <!-- Right Turn -->

    <!-- Flows: Member 1 can now distribute traffic across these routes -->
    <flow id="f_sn" type="car" route="s_to_n" begin="0" end="3600" vehsPerHour="400"/>
    <flow id="f_sw" type="car" route="s_to_w" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_se" type="car" route="s_to_e" begin="0" end="3600" vehsPerHour="100"/>
</routes>