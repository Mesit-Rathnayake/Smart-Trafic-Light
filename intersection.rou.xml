<routes>
    <!-- Define a standard passenger car -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5.0" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>

    <!-- Define the paths -->
    <route id="L2R" edges="L2C C2R"/>
    <route id="R2L" edges="R2C C2L"/>
    <route id="T2B" edges="T2C C2B"/>
    <route id="B2T" edges="B2C C2T"/>

    <!-- Create flows (Total vehicles per hour) -->
    <!-- This simulates a 'Medium' density scenario -->
    <flow id="flow_L2R" type="car" route="L2R" begin="0" end="3600" vehsPerHour="400"/>
    <flow id="flow_R2L" type="car" route="R2L" begin="0" end="3600" vehsPerHour="400"/>
    <flow id="flow_T2B" type="car" route="T2B" begin="0" end="3600" vehsPerHour="300"/>
    <flow id="flow_B2T" type="car" route="B2T" begin="0" end="3600" vehsPerHour="300"/>
</routes>