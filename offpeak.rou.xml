<routes>
    <!-- 1. Define the Vehicle Type -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5.0" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>

    <!-- 2. Define Routes -->
    <route id="s_straight" edges="B2C C2T"/>
    <route id="s_left" edges="B2C C2L"/>
    <route id="s_right" edges="B2C C2R"/>

    <route id="n_straight" edges="T2C C2B"/>
    <route id="n_left" edges="T2C C2R"/>
    <route id="n_right" edges="T2C C2L"/>

    <route id="w_straight" edges="L2C C2R"/>
    <route id="w_left" edges="L2C C2B"/>
    <route id="w_right" edges="L2C C2T"/>

    <route id="e_straight" edges="R2C C2L"/>
    <route id="e_left" edges="R2C C2T"/>
    <route id="e_right" edges="R2C C2B"/>

    <!-- 3. Traffic Flows (Scenario: OFF-PEAK - Low Density with Turns) -->
    <!-- South & North: ~200 total per direction -->
    <flow id="flow_s_str" type="car" route="s_straight" begin="0" end="3600" vehsPerHour="140"/>
    <flow id="flow_s_lft" type="car" route="s_left" begin="0" end="3600" vehsPerHour="30"/>
    <flow id="flow_s_rgt" type="car" route="s_right" begin="0" end="3600" vehsPerHour="30"/>
    
    <flow id="flow_n_str" type="car" route="n_straight" begin="0" end="3600" vehsPerHour="140"/>
    <flow id="flow_n_lft" type="car" route="n_left" begin="0" end="3600" vehsPerHour="30"/>
    <flow id="flow_n_rgt" type="car" route="n_right" begin="0" end="3600" vehsPerHour="30"/>

    <!-- West & East: ~150 total per direction -->
    <flow id="flow_w_str" type="car" route="w_straight" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="flow_w_lft" type="car" route="w_left" begin="0" end="3600" vehsPerHour="25"/>
    <flow id="flow_w_rgt" type="car" route="w_right" begin="0" end="3600" vehsPerHour="25"/>

    <flow id="flow_e_str" type="car" route="e_straight" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="flow_e_lft" type="car" route="e_left" begin="0" end="3600" vehsPerHour="25"/>
    <flow id="flow_e_rgt" type="car" route="e_right" begin="0" end="3600" vehsPerHour="25"/>
</routes>